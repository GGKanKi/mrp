# Example environment variables for Novus MRP
# Copy this file to .env and fill in the real values before running.

# Google API credentials
GOOGLE_CRED_PATH=json_f/new_cred.json
GOOGLE_TOKEN_PATH=json_f/token.json

# Google Sheets links (replace with your own if needed)
USER_LOG='your_user_log_sheet_id'
ACTION_LOG='your_action_log_sheet_id'
PRODUCT_LOG='your_product_log_sheet_id'
SETTING_LOG='your_setting_log_sheet_id'
RESTOCK_LOG='your_restock_log_sheet_id'

# Optional API key for other services
API_KEY=your_api_key_here
